# Mezo testnet (matsnet)
NEXT_PUBLIC_CHAIN_ID=31611
NEXT_PUBLIC_RPC_URL=https://rpc.test.mezo.org
NEXT_PUBLIC_EXPLORER_URL=https://explorer.test.mezo.org

# Deployed contract addresses (from `forge script Deploy.s.sol`)
NEXT_PUBLIC_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_REPUTATION_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BADGE_ADDRESS=0x0000000000000000000000000000000000000000

# Mezo banking integrations (TESTNET — fill with real Mezo testnet addresses).
# Both default to the zero address, in which case the UI falls back to native-BTC circles
# only and the yield-vault toggle is disabled.
NEXT_PUBLIC_MUSD_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_YIELD_VAULT_ADDRESS=0x0000000000000000000000000000000000000000

# WalletConnect (optional)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
